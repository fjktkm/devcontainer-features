{
    "default": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent-persistence": {}
        }
    },
    "workspace_scope": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent-persistence": {
                "scope": "workspace"
            }
        }
    },
    "claude_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent-persistence": {
                "codex": false,
                "gemini": false,
                "github-cli": false
            }
        }
    }
}
